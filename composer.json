{
    "name": "yacoubalhaidari/zkfinger-laravel",
    "description": "Laravel package for ZKTeco ZKFinger SDK via local agent bridge",
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4|^8.5",
        "laravel/framework": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.5"
    },
    "autoload": {
        "psr-4": {
            "Yacoubalhaidari\\ZKFinger\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yacoubalhaidari\\ZKFinger\\ZKFingerServiceProvider"
            ]
        }
    }
}
